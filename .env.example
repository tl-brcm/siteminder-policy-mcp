SITE_MINDER_BASE_URL=https://ps8:8443
SITE_MINDER_USERNAME=
SITE_MINDER_PASSWORD=
VERIFY_SSL=false
LOG_LEVEL=DEBUG

# MCP Discovery Metadata
MCP_AUTHORIZATION_SERVERS=https://ssp-215.demo-broadcom.com/default/
MCP_RESOURCE_URL=https://mcp.vm.demo:8443/sm-policy/mcp
MCP_APP_NAME=siteminder-policy-assistant
MCP_SCOPES_SUPPORTED=email,groups,offline_access,openid,phone,profile,siteminder:access
MCP_AUTH_TOKEN=

# IDSP OIDC Configuration (FastMCP 3.0 OIDCProxy)
IDSP_OIDC_URL=https://ssp-215.demo-broadcom.com/default
IDSP_CLIENT_ID=your-client-id
IDSP_CLIENT_SECRET=your-client-secret
IDSP_AUDIENCE=https://mcp.vm.demo:8443/sm-policy/mcp
IDSP_SCOPES=openid profile email groups address offline_access

# Proxy configuration
MCP_BASE_URL=https://mcp.vm.demo:8443/sm-policy

USE_HTTPS=true